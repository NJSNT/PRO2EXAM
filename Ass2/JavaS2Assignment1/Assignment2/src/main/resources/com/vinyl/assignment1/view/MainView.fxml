<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vinyl.assignment1.view.MainViewController">
   <top>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="Vinyl Library Management System" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="currentUserLabel" text="User: Ondrej" textFill="#7f8c8d">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="15.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f5f6fa;">
               <children>
                  <Button fx:id="startSimulationButton" mnemonicParsing="false" onAction="#onStartSimulationClicked" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Start Simulator" />
                  <Button fx:id="stopSimulationButton" mnemonicParsing="false" onAction="#onStopSimulationClicked" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Stop Simulator" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="vinylTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="titleColumn" prefWidth="300.0" text="Title" />
                <TableColumn fx:id="artistColumn" prefWidth="200.0" text="Artist" />
                  <TableColumn fx:id="yearColumn" prefWidth="100.0" text="Year" />
                  <TableColumn fx:id="stateColumn" prefWidth="150.0" text="Current State" />
              </columns>
            </TableView>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="reserveButton" mnemonicParsing="false" onAction="#onReserveClicked" prefWidth="100.0" text="Reserve" />
            <Button fx:id="borrowButton" mnemonicParsing="false" onAction="#onBorrowClicked" prefWidth="100.0" text="Borrow" />
            <Button fx:id="returnButton" mnemonicParsing="false" onAction="#onReturnClicked" prefWidth="100.0" text="Return" />
            <Button fx:id="removeButton" mnemonicParsing="false" onAction="#onRemoveClicked" prefWidth="100.0" text="Remove" />
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="addVinylButton" mnemonicParsing="false" onAction="#onAddVinylClicked" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="+ Add New Vinyl" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>
